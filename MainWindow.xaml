<Window x:Class="Schmube.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schmube Control"
        Height="720"
        Width="1120"
        MinHeight="600"
        MinWidth="860"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SelectableInfoTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Schmube" />
            <TextBlock Foreground="#4B5563" Text="Compact IPTV browser with Xtream loading, local logo cache, favorites, and guide data" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Playlist or Stream URL" />
            <TextBox x:Name="StreamUrlTextBox"
                     Height="32"
                     Padding="10,6"
                     HorizontalContentAlignment="Left"
                     VerticalContentAlignment="Center"
                     ToolTip="Paste an M3U playlist URL, a direct stream URL, or an Xtream get.php URL." />
        </StackPanel>

        <WrapPanel Grid.Row="2" Margin="0,0,0,10" ItemHeight="58">
            <StackPanel Width="240" Margin="0,0,12,0">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="User-Agent (optional)" />
                <TextBox x:Name="UserAgentTextBox" Height="32" Padding="10,6" />
            </StackPanel>

            <StackPanel Width="240" Margin="0,0,12,0">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Referer (optional)" />
                <TextBox x:Name="RefererTextBox" Height="32" Padding="10,6" />
            </StackPanel>

            <CheckBox x:Name="KeepOnTopCheckBox"
                      Margin="0,26,16,0"
                      VerticalAlignment="Top"
                      Content="Keep player window on top" />
        </WrapPanel>

        <DockPanel Grid.Row="3" Margin="0,0,0,10" LastChildFill="True">
            <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <StackPanel Width="170" Margin="0,0,10,0">
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Search" />
                    <TextBox x:Name="ChannelSearchTextBox"
                             Height="32"
                             Padding="10,6"
                             TextChanged="ChannelSearchTextBox_TextChanged" />
                </StackPanel>

                <StackPanel Width="170" Margin="0,0,10,0">
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Group" />
                    <ComboBox x:Name="GroupFilterComboBox"
                              Height="32"
                              SelectionChanged="GroupFilterComboBox_SelectionChanged" />
                </StackPanel>

                <CheckBox x:Name="FavoritesOnlyCheckBox"
                          Margin="0,26,12,0"
                          VerticalAlignment="Top"
                          Content="Favorites only"
                          Click="FavoritesOnlyCheckBox_Click" />
            </WrapPanel>

            <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Bottom">
                <Button x:Name="LoadChannelsButton" Width="106" Height="32" Margin="0,0,8,0" Content="Load Channels" Click="LoadChannelsButton_Click" />
                <Button Width="102" Height="32" Margin="0,0,8,0" Content="Play Selected" Click="PlaySelectedButton_Click" />
                <Button Width="86" Height="32" Margin="0,0,8,0" Content="Play URL" Click="PlayUrlButton_Click" />
                <Button Width="96" Height="32" Margin="0,0,8,0" Content="Open Player" Click="OpenPlayerButton_Click" />
                <Button Width="80" Height="32" Margin="0,0,8,0" Content="Stop" Click="StopButton_Click" />
                <Button Width="72" Height="32" Content="Save" Click="SaveButton_Click" />
            </WrapPanel>
        </DockPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#F9FAFB"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Selected Channel" />

                        <Grid Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="104"
                                    Height="64"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">
                                <Image x:Name="SelectedChannelLogoImage"
                                       Stretch="Uniform"
                                       Margin="6" />
                            </Border>

                            <StackPanel Grid.Column="2">
                                <TextBox x:Name="SelectedChannelNameTextBox"
                                         Style="{StaticResource SelectableInfoTextBoxStyle}"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         Margin="0,0,0,4" />
                                <TextBox x:Name="SelectedChannelFavoriteStateTextBox"
                                         Style="{StaticResource SelectableInfoTextBoxStyle}"
                                         Margin="0,0,0,10"
                                         Foreground="#4B5563" />
                                <Button x:Name="ToggleFavoriteButton"
                                        Width="124"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        Content="Add Favorite"
                                        Click="ToggleFavoriteButton_Click" />
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="ChannelSummaryTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}"
                                 Margin="0,0,0,12"
                                 Foreground="#4B5563" />

                        <TextBlock FontWeight="SemiBold" Text="Group" />
                        <TextBox x:Name="SelectedChannelGroupTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}" />

                        <TextBlock FontWeight="SemiBold" Text="Channel ID" />
                        <TextBox x:Name="SelectedChannelIdTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}" />

                        <TextBlock FontWeight="SemiBold" Text="Configured Default Group" />
                        <TextBox x:Name="ConfiguredDefaultTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}" />

                        <TextBlock FontWeight="SemiBold" Text="Program Guide" />
                        <TextBox x:Name="ProgramGuideStatusTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}"
                                 Margin="0,4,0,8"
                                 Foreground="#4B5563" />

                        <ListBox x:Name="ProgramGuideListBox"
                                 Height="220"
                                 Margin="0,0,0,12"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Background="#FFFFFF"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBox Style="{StaticResource SelectableInfoTextBoxStyle}"
                                                     Margin="0,0,0,2"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding Title, Mode=OneWay}" />
                                            <TextBox Style="{StaticResource SelectableInfoTextBoxStyle}"
                                                     Margin="0,0,0,2"
                                                     Foreground="#4B5563"
                                                     Text="{Binding TimeRange, Mode=OneWay}" />
                                            <TextBox Style="{StaticResource SelectableInfoTextBoxStyle}"
                                                     Margin="0"
                                                     Text="{Binding Description, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock FontWeight="SemiBold" Text="Stream URL" />
                        <TextBox x:Name="SelectedChannelUrlTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}"
                                 Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E5E7EB"
                          ShowsPreview="True" />

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6">
                <ListView x:Name="ChannelsListView"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SelectionChanged="ChannelsListView_SelectionChanged"
                          MouseDoubleClick="ChannelsListView_MouseDoubleClick">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="Fav" Width="38" DisplayMemberBinding="{Binding FavoriteMarker}" />
                            <GridViewColumn Header="Logo" Width="64">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="52"
                                                Height="30"
                                                Background="#F3F4F6"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Image Width="48"
                                                   Height="26"
                                                   Margin="2"
                                                   Stretch="Uniform"
                                                   Source="{Binding LogoSource}" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Channel" Width="280" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Group" Width="220" DisplayMemberBinding="{Binding GroupTitle}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>

        <Border Grid.Row="5"
                Margin="0,10,0,0"
                Background="#111827"
                CornerRadius="8"
                Padding="12,10">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#F9FAFB"
                       Text="Ready. Your configured subscription URL is loaded automatically." />
        </Border>
    </Grid>
</Window>

