<Window x:Class="Schmube.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schmube Control"
        Height="780"
        Width="1260"
        MinHeight="660"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Schmube" />
            <TextBlock Foreground="#4B5563" Text="Windows IPTV browser and player with Xtream support, favorites, logos, and default group loading" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Playlist or Stream URL" />
            <TextBox x:Name="StreamUrlTextBox"
                     Height="34"
                     Padding="10,7"
                     HorizontalContentAlignment="Left"
                     VerticalContentAlignment="Center"
                     ToolTip="Paste an M3U playlist URL, a direct stream URL, or an Xtream get.php URL." />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="User-Agent (optional)" />
                <TextBox x:Name="UserAgentTextBox" Height="34" Padding="10,7" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Referer (optional)" />
                <TextBox x:Name="RefererTextBox" Height="34" Padding="10,7" />
            </StackPanel>

            <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                <CheckBox x:Name="KeepOnTopCheckBox" Content="Keep player window on top" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Search" />
                    <TextBox x:Name="ChannelSearchTextBox"
                             Height="34"
                             Padding="10,7"
                             TextChanged="ChannelSearchTextBox_TextChanged" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Group" />
                    <ComboBox x:Name="GroupFilterComboBox"
                              Height="34"
                              SelectionChanged="GroupFilterComboBox_SelectionChanged" />
                </StackPanel>

                <CheckBox x:Name="FavoritesOnlyCheckBox"
                          Grid.Column="4"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,8"
                          Content="Favorites only"
                          Click="FavoritesOnlyCheckBox_Click" />

                <CheckBox x:Name="ApplyDefaultGroupsCheckBox"
                          Grid.Column="6"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,8"
                          Content="Apply default groups"
                          Click="ApplyDefaultGroupsCheckBox_Click" />

                <TextBlock x:Name="ChannelSummaryTextBlock"
                           Grid.Column="7"
                           Margin="16,0,0,8"
                           VerticalAlignment="Bottom"
                           Foreground="#4B5563"
                           Text="No channels loaded." />

                <WrapPanel Grid.Column="8" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button x:Name="LoadChannelsButton" Width="110" Height="34" Margin="0,0,8,0" Content="Load Channels" Click="LoadChannelsButton_Click" />
                    <Button Width="110" Height="34" Margin="0,0,8,0" Content="Play Selected" Click="PlaySelectedButton_Click" />
                    <Button Width="90" Height="34" Margin="0,0,8,0" Content="Play URL" Click="PlayUrlButton_Click" />
                    <Button Width="100" Height="34" Margin="0,0,8,0" Content="Open Player" Click="OpenPlayerButton_Click" />
                    <Button Width="90" Height="34" Margin="0,0,8,0" Content="Stop" Click="StopButton_Click" />
                    <Button Width="80" Height="34" Content="Save" Click="SaveButton_Click" />
                </WrapPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Selected Channel" />

                        <Grid Margin="0,14,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="116" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="116"
                                    Height="72"
                                    CornerRadius="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">
                                <Image x:Name="SelectedChannelLogoImage"
                                       Stretch="Uniform"
                                       Margin="6" />
                            </Border>

                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="SelectedChannelNameTextBlock"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="No channel selected"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="SelectedChannelFavoriteStateTextBlock"
                                           Margin="0,6,0,10"
                                           Foreground="#4B5563"
                                           Text="Not a favorite" />
                                <Button x:Name="ToggleFavoriteButton"
                                        Width="130"
                                        Height="32"
                                        HorizontalAlignment="Left"
                                        Content="Add Favorite"
                                        Click="ToggleFavoriteButton_Click" />
                            </StackPanel>
                        </Grid>

                        <TextBlock FontWeight="SemiBold" Text="Group" />
                        <TextBlock x:Name="SelectedChannelGroupTextBlock"
                                   Margin="0,4,0,12"
                                   Foreground="#374151"
                                   Text="Load a playlist to browse channels." />

                        <TextBlock FontWeight="SemiBold" Text="Channel ID" />
                        <TextBlock x:Name="SelectedChannelIdTextBlock"
                                   Margin="0,4,0,12"
                                   Foreground="#374151"
                                   Text="Not available" />

                        <TextBlock FontWeight="SemiBold" Text="Configured Default Groups" />
                        <TextBlock x:Name="ConfiguredDefaultsTextBlock"
                                   Margin="0,4,0,12"
                                   Foreground="#374151"
                                   Text="All groups" />

                        <TextBlock FontWeight="SemiBold" Text="Stream URL" />
                        <TextBlock x:Name="SelectedChannelUrlTextBlock"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Text="Load the playlist and choose a channel from the list." />

                        <Border Margin="0,18,0,0"
                                Padding="12"
                                CornerRadius="8"
                                Background="#EEF2FF">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#312E81"
                                       Text="Favorites are persisted in your user settings. Double-click a channel to play it. The app-level config file controls the built-in subscription URL and default groups." />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#FFFFFF"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <ListView x:Name="ChannelsListView"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              SelectionChanged="ChannelsListView_SelectionChanged"
                              MouseDoubleClick="ChannelsListView_MouseDoubleClick">
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Header="Fav" Width="40" DisplayMemberBinding="{Binding FavoriteMarker}" />
                                <GridViewColumn Header="Logo" Width="68">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="56"
                                                    Height="32"
                                                    Background="#F3F4F6"
                                                    BorderBrush="#E5E7EB"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <Image Width="52"
                                                       Height="28"
                                                       Margin="2"
                                                       Stretch="Uniform"
                                                       Source="{Binding TvgLogo}" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Channel" Width="320" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Group" Width="260" DisplayMemberBinding="{Binding GroupTitle}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,12,0,0"
                Background="#111827"
                CornerRadius="8"
                Padding="12,10">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#F9FAFB"
                       Text="Ready. Your configured subscription URL is loaded automatically." />
        </Border>
    </Grid>
</Window>
