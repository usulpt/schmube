<Window x:Class="Schmube.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Schmube Control"
        Height="720"
        Width="1120"
        MinHeight="600"
        MinWidth="860"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SelectableInfoTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
        </Style>
        <Style x:Key="SelectedChannelFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="SelectedChannelFieldValueStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource SelectableInfoTextBoxStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="MainGroupComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1"
                                        BorderThickness="1,0,0,0"
                                        BorderBrush="{DynamicResource BorderBrush}">
                                    <Path Width="10"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{DynamicResource PrimaryTextBrush}"
                                          Data="M 0 0 L 10 0 L 5 6 Z" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource HoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource HoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MainGroupComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Style="{StaticResource MainGroupComboBoxToggleButtonStyle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" />

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,36,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              TextElement.Foreground="{DynamicResource PrimaryTextBrush}" />

                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="10,0,36,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Visibility="Hidden"
                                     Focusable="True"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Border x:Name="PopupBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        Margin="0,4,0,0"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Margin="2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="28" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="{DynamicResource SelectionBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Schmube" />
            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="Compact IPTV browser with Xtream loading, group flag mapping, live guide previews, recents, recording, and reconnect-ready playback" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Playlist or Stream URL" />
            <TextBox x:Name="StreamUrlTextBox"
                     Height="32"
                     Padding="10,6"
                     HorizontalContentAlignment="Left"
                     VerticalContentAlignment="Center"
                     ToolTip="Paste an M3U playlist URL, a direct stream URL, or an Xtream get.php URL." />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10" Orientation="Horizontal">
            <CheckBox x:Name="KeepOnTopCheckBox"
                      Margin="0,0,14,0"
                      VerticalAlignment="Center"
                      Content="Keep player window on top"
                      ToolTip="Keep the separate player window above other windows while a stream is open." />
            <CheckBox x:Name="DarkModeCheckBox"
                      VerticalAlignment="Center"
                      Content="Dark mode"
                      Click="DarkModeCheckBox_Click"
                      ToolTip="Toggle the application theme." />
        </StackPanel>

        <DockPanel Grid.Row="3" Margin="0,0,0,10" LastChildFill="True">
            <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <StackPanel Width="170" Margin="0,0,10,0">
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Search" />
                    <TextBox x:Name="ChannelSearchTextBox"
                             Height="32"
                             Padding="10,6"
                             TextChanged="ChannelSearchTextBox_TextChanged" />
                </StackPanel>

                <StackPanel Width="170" Margin="0,0,10,0">
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Group" />
                    <ComboBox x:Name="GroupFilterComboBox"
                              Style="{StaticResource MainGroupComboBoxStyle}"
                              Height="32"
                              SelectionChanged="GroupFilterComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="SearchAllGroupsCheckBox"
                          Margin="0,26,12,0"
                          VerticalAlignment="Top"
                          Content="Search all groups"
                          ToolTip="When search text is present, ignore the selected group and search across all loaded channels."
                          Click="SearchAllGroupsCheckBox_Click" />

                <CheckBox x:Name="FavoritesOnlyCheckBox"
                          Margin="0,26,12,0"
                          VerticalAlignment="Top"
                          Content="Favorites only"
                          ToolTip="Show only channels marked as favorites."
                          Click="FavoritesOnlyCheckBox_Click" />

                <CheckBox x:Name="RecentOnlyCheckBox"
                          Margin="0,26,12,0"
                          VerticalAlignment="Top"
                          Content="Recent only"
                          ToolTip="Show only channels you played recently."
                          Click="RecentOnlyCheckBox_Click" />
            </WrapPanel>

            <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Bottom">
                <Button x:Name="LoadChannelsButton" Width="106" Height="32" Margin="0,0,8,0" Content="Load Channels" Click="LoadChannelsButton_Click" ToolTip="Fetch channels from the configured playlist or Xtream account." />
                <Button x:Name="TvListingsButton" Width="92" Height="32" Margin="0,0,8,0" Content="TV Listings" Click="TvListingsButton_Click" ToolTip="Open a football match page, generate compatible playlist channels from its broadcaster listing, and load them as a temporary navigation list." />
                <Button x:Name="ClearTempListButton" Width="92" Height="32" Margin="0,0,8,0" Content="Clear Temp" Click="ClearTempListButton_Click" ToolTip="Clear the active temporary channel list created from TV listings results." />
                <Button x:Name="PlaySelectedButton" Width="102" Height="32" Margin="0,0,8,0" Content="Play Selected" Click="PlaySelectedButton_Click" ToolTip="Play the currently selected channel in the player window." />
                <Button x:Name="PlayUrlButton" Width="86" Height="32" Margin="0,0,8,0" Content="Play URL" Click="PlayUrlButton_Click" ToolTip="Play the raw URL above directly when it is a single stream." />
                <Button x:Name="OpenPlayerButton" Width="96" Height="32" Margin="0,0,8,0" Content="Open Player" Click="OpenPlayerButton_Click" ToolTip="Open the separate resizable player window without starting playback." />
                <Button x:Name="StopPlaybackButton" Width="80" Height="32" Margin="0,0,8,0" Content="Stop" Click="StopButton_Click" ToolTip="Stop playback in the player window." />
                <Button x:Name="SaveSettingsButton" Width="72" Height="32" Content="Save" Click="SaveButton_Click" ToolTip="Save the current URL, favorites, recents, and window settings locally." />
            </WrapPanel>
        </DockPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Selected Channel" />

                        <Grid Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="104"
                                    Height="64"
                                    CornerRadius="8"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Image x:Name="SelectedChannelLogoImage"
                                       Stretch="Uniform"
                                       Margin="6" />
                            </Border>

                            <StackPanel Grid.Column="2">
                                <TextBox x:Name="SelectedChannelNameTextBox"
                                         Style="{StaticResource SelectableInfoTextBoxStyle}"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         Margin="0,0,0,4" />
                                <TextBox x:Name="SelectedChannelFavoriteStateTextBox"
                                         Style="{StaticResource SelectableInfoTextBoxStyle}"
                                         Margin="0,0,0,10"
                                         Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Button x:Name="ToggleFavoriteButton"
                                        Width="124"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        Content="Add Favorite"
                                        Click="ToggleFavoriteButton_Click"
                                        ToolTip="Add or remove the selected channel from your favorites." />
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="ChannelSummaryTextBox"
                                 Style="{StaticResource SelectableInfoTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 Foreground="{DynamicResource SecondaryTextBrush}" />

                        <TextBlock Style="{StaticResource SelectedChannelFieldLabelStyle}" Text="Group" />
                        <TextBox x:Name="SelectedChannelGroupTextBox"
                                 Style="{StaticResource SelectedChannelFieldValueStyle}" />

                        <TextBlock Style="{StaticResource SelectedChannelFieldLabelStyle}" Text="Channel ID" />
                        <TextBox x:Name="SelectedChannelIdTextBox"
                                 Style="{StaticResource SelectedChannelFieldValueStyle}" />

                        <TextBlock Style="{StaticResource SelectedChannelFieldLabelStyle}" Text="Stream URL" />
                        <TextBox x:Name="SelectedChannelUrlTextBox"
                                 Style="{StaticResource SelectedChannelFieldValueStyle}" />

                        <TextBlock Style="{StaticResource SelectedChannelFieldLabelStyle}" Text="Program Guide" />
                        <TextBox x:Name="ProgramGuideStatusTextBox"
                                 Style="{StaticResource SelectedChannelFieldValueStyle}"
                                 Margin="0,0,0,8"
                                 Foreground="{DynamicResource SecondaryTextBrush}" />

                        <ListBox x:Name="ProgramGuideListBox"
                                 Height="220"
                                 Margin="0,0,0,12"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBox Style="{StaticResource SelectableInfoTextBoxStyle}"
                                                     Margin="0,0,0,2"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding Title, Mode=OneWay}" />
                                            <TextBox Style="{StaticResource SelectableInfoTextBoxStyle}"
                                                     Margin="0,0,0,2"
                                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                                     Text="{Binding TimeRange, Mode=OneWay}" />
                                            <TextBox Style="{StaticResource SelectableInfoTextBoxStyle}"
                                                     Margin="0"
                                                     Text="{Binding Description, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource DividerBrush}"
                          ShowsPreview="True" />

            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6">
                <ListView x:Name="ChannelsListView"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          SelectionChanged="ChannelsListView_SelectionChanged"
                          MouseDoubleClick="ChannelsListView_MouseDoubleClick">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="Fav" Width="38" DisplayMemberBinding="{Binding FavoriteMarker}" />
                            <GridViewColumn Header="Recent" Width="52" DisplayMemberBinding="{Binding RecentMarker}" />
                            <GridViewColumn Header="Flag" Width="56">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="36"
                                                Height="24"
                                                Padding="0"
                                                CornerRadius="6"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource DividerBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GroupFlag}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Image Width="32"
                                                   Height="22"
                                                   Stretch="UniformToFill"
                                                   Source="{Binding GroupFlag}" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Logo" Width="64">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="52"
                                                Height="30"
                                                Background="{DynamicResource SurfaceMutedBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Image Width="48"
                                                   Height="26"
                                                   Margin="2"
                                                   Stretch="Uniform"
                                                   Source="{Binding LogoSource}" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Channel" Width="220" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Now" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding NowTitle}"
                                                   ToolTip="{Binding NowTitle}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Next" Width="190">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding NextTitle}"
                                                   ToolTip="{Binding NextTitle}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Group" Width="170" DisplayMemberBinding="{Binding GroupDisplayTitle}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>

        <Border Grid.Row="5"
                Margin="0,10,0,0"
                Background="{DynamicResource StatusSurfaceBrush}"
                CornerRadius="8"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="HintTextBlock"
                           Grid.Column="0"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           Text="Focus a control to see what it does." />

                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="2"
                           Foreground="{DynamicResource InverseTextBrush}"
                           TextAlignment="Right"
                           Text="Ready. Your configured subscription URL is loaded automatically." />
            </Grid>
        </Border>
    </Grid>
</Window>

