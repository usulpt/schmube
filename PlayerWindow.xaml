<Window x:Class="Schmube.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Schmube Player"
        Width="1080"
        Height="640"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="#111827" LastChildFill="True" Height="46">
            <Button Width="90"
                    Margin="10,6,0,6"
                    Content="Stop"
                    Click="StopButton_Click"
                    DockPanel.Dock="Right" />

            <Button x:Name="OpenRecordingsButton"
                    Width="120"
                    Margin="10,6,0,6"
                    Content="Open Folder"
                    Click="OpenRecordingsButton_Click"
                    DockPanel.Dock="Right" />

            <Button x:Name="ToggleRecordingButton"
                    Width="104"
                    Margin="10,6,0,6"
                    Content="Start Rec"
                    Click="ToggleRecordingButton_Click"
                    DockPanel.Dock="Right" />

            <StackPanel Margin="12,0,12,0"
                        VerticalAlignment="Center">
                <TextBlock x:Name="NowPlayingText"
                           Foreground="#F9FAFB"
                           Text="No stream loaded" />
                <TextBlock x:Name="RecordingText"
                           Foreground="#FCA5A5"
                           FontWeight="SemiBold"
                           Visibility="Collapsed"
                           Text="REC" />
            </StackPanel>
        </DockPanel>

        <vlc:VideoView x:Name="VideoSurface" Grid.Row="1" />

        <Border Grid.Row="2" Background="#111827" Padding="12,8">
            <TextBlock x:Name="StatusText"
                       Foreground="#D1D5DB"
                       Text="Ready." />
        </Border>
    </Grid>
</Window>
