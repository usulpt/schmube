<Window x:Class="Schmube.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Schmube Player"
        Width="1080"
        Height="640"
        MinWidth="480"
        MinHeight="320"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PlayerStateButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="Active">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
                <Trigger Property="Tag" Value="Recording">
                    <Setter Property="Background" Value="#DC2626" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#F87171" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlayerBadgeStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PlayerScheduleTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
            <Setter Property="SelectionTextBrush" Value="{DynamicResource SelectionTextBrush}" />
            <Setter Property="Padding" Value="6,3" />
        </Style>
        <Style x:Key="PlayerScheduleDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style TargetType="{x:Type primitives:DatePickerTextBox}">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource PlayerBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="PlayerToolbar" Grid.Row="0" Background="{DynamicResource PlayerChromeBrush}" MinHeight="58">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="10,8,0,8">
                <Button Width="58"
                        Margin="0,0,8,0"
                        Content="Prev"
                        Click="PreviousChannelButton_Click"
                        ToolTip="Previous visible channel (Page Up or Ctrl+Left)." />
                <Button Width="58"
                        Margin="0,0,8,0"
                        Content="Next"
                        Click="NextChannelButton_Click"
                        ToolTip="Next visible channel (Page Down or Ctrl+Right)." />
            </StackPanel>

            <Grid Grid.Column="1"
                  Margin="12,0,12,0"
                  VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           LastChildFill="True"
                           VerticalAlignment="Center">
                    <Image x:Name="NowPlayingLogoImage"
                           DockPanel.Dock="Left"
                           Width="28"
                           Height="24"
                           Margin="0,0,8,0"
                           Stretch="Uniform"
                           Visibility="Collapsed" />
                    <TextBlock x:Name="NowPlayingText"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource InverseTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               Text="No stream loaded" />
                </DockPanel>

                <DockPanel Grid.Row="1"
                           LastChildFill="True">
                    <TextBlock x:Name="PlaybackStateBadgeText"
                               DockPanel.Dock="Left"
                               Style="{StaticResource PlayerBadgeStyle}"
                               Text="Idle" />
                    <TextBlock x:Name="RecordingText"
                               DockPanel.Dock="Left"
                               Style="{StaticResource PlayerBadgeStyle}"
                               Margin="0,0,12,0"
                               Foreground="{DynamicResource DangerTextBrush}"
                               FontWeight="SemiBold"
                               Visibility="Collapsed"
                               Text="REC" />
                    <TextBlock x:Name="VolumeText"
                               Foreground="{DynamicResource AccentTextBrush}"
                               FontWeight="SemiBold"
                               MinWidth="92"
                               TextTrimming="CharacterEllipsis"
                               Text="Volume 100%" />
                </DockPanel>
            </Grid>

            <StackPanel Grid.Column="2"
                        Margin="0,8,10,8"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Width="52"
                        Margin="0,0,6,0"
                        Content="Vol -"
                        Click="VolumeDownButton_Click"
                        ToolTip="Lower volume (Down Arrow)." />
                <Button x:Name="ToggleMuteButton"
                        Style="{StaticResource PlayerStateButtonStyle}"
                        Width="66"
                        Margin="0,0,6,0"
                        Content="Mute"
                        Click="ToggleMuteButton_Click"
                        ToolTip="Mute or unmute audio (M)." />
                <Button Width="52"
                        Margin="0,0,6,0"
                        Content="Vol +"
                        Click="VolumeUpButton_Click"
                        ToolTip="Raise volume (Up Arrow)." />
                <Button x:Name="FullScreenButton"
                        Width="58"
                        Margin="0,0,6,0"
                        Content="Full"
                        Click="FullScreenButton_Click"
                        ToolTip="Toggle full screen (F or Alt+Enter, Escape to exit)." />
                <Button x:Name="TakeScreenshotButton"
                        Width="62"
                        Margin="0,0,6,0"
                        Content="Shot"
                        Click="TakeScreenshotButton_Click"
                        ToolTip="Save a screenshot of the current frame (Ctrl+S)." />
                <Button x:Name="ToggleNetworkDebitButton"
                        Style="{StaticResource PlayerStateButtonStyle}"
                        Width="58"
                        Margin="0,0,6,0"
                        Content="Net"
                        Click="ToggleNetworkDebitButton_Click"
                        ToolTip="Show or hide network debit in the buffering status. Off by default." />
                <Button x:Name="ToggleRecordingButton"
                        Style="{StaticResource PlayerStateButtonStyle}"
                        Width="76"
                        Margin="0,0,6,0"
                        Content="Record"
                        Click="ToggleRecordingButton_Click"
                        ToolTip="Start or stop recording the active stream." />
                <Button x:Name="OpenRecordingsButton"
                        Width="76"
                        Content="Folder"
                        Click="OpenRecordingsButton_Click"
                        ToolTip="Open the recordings folder." />
            </StackPanel>
        </Grid>

        <StackPanel x:Name="RecordingSchedulePanel"
                    Grid.Row="1"
                    Background="{DynamicResource PlayerChromeBrush}"
                    Margin="0,1,0,0">
            <WrapPanel MinHeight="42"
                       VerticalAlignment="Center"
                       ItemHeight="30">
                <TextBlock Margin="12,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           FontWeight="SemiBold"
                           Text="Schedule" />
                <TextBlock Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           Text="Date" />
                <DatePicker x:Name="RecordingScheduleDatePicker"
                            Style="{StaticResource PlayerScheduleDatePickerStyle}"
                            Width="122"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />
                <TextBlock Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           Text="Time" />
                <TextBox x:Name="RecordingScheduleTimeTextBox"
                         Style="{StaticResource PlayerScheduleTextBoxStyle}"
                         Width="58"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         ToolTip="Start time, for example 21:30." />
                <TextBlock Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           Text="Minutes" />
                <TextBox x:Name="RecordingScheduleDurationTextBox"
                         Style="{StaticResource PlayerScheduleTextBoxStyle}"
                         Width="54"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         ToolTip="Recording duration in minutes." />
                <Button x:Name="ScheduleRecordingButton"
                        Width="82"
                        Margin="0,0,6,0"
                        Content="Schedule"
                        Click="ScheduleRecordingButton_Click"
                        ToolTip="Schedule recording for the current channel." />
                <Button x:Name="CancelRecordingScheduleButton"
                        Width="104"
                        Margin="0,0,6,0"
                        Content="Cancel Pick"
                        Click="CancelRecordingScheduleButton_Click"
                        ToolTip="Cancel the selected scheduled recording, or the next one if none is selected." />
                <Button x:Name="ToggleRecordingHistoryButton"
                        Width="78"
                        Margin="0,0,10,0"
                        Content="History"
                        Click="ToggleRecordingHistoryButton_Click"
                        ToolTip="Show scheduled and completed recordings." />
                <TextBlock x:Name="RecordingScheduleText"
                           MinWidth="220"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Text="No recording scheduled." />
            </WrapPanel>

            <Grid x:Name="RecordingHistoryPanel"
                  Visibility="Collapsed"
                  MinHeight="126"
                  MaxHeight="180"
                  Margin="12,0,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0"
                           Margin="0,0,0,4"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           FontWeight="SemiBold"
                           Text="Scheduled" />
                <ListBox x:Name="RecordingSchedulesListBox"
                         Grid.Column="0"
                         Grid.Row="1"
                         MinHeight="76"
                         Background="{DynamicResource InputBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         DisplayMemberPath="Summary" />

                <TextBlock Grid.Column="2"
                           Margin="0,0,0,4"
                           Foreground="{DynamicResource InverseMutedTextBrush}"
                           FontWeight="SemiBold"
                           Text="Recent Recordings" />
                <ListBox x:Name="RecordingHistoryListBox"
                         Grid.Column="2"
                         Grid.Row="1"
                         MinHeight="76"
                         Background="{DynamicResource InputBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         DisplayMemberPath="Summary" />

                <WrapPanel Grid.Column="2"
                           Grid.Row="2"
                           Margin="0,6,0,0">
                    <Button Width="64"
                            Margin="0,0,6,0"
                            Content="Open"
                            Click="OpenRecordingHistoryItemButton_Click" />
                    <Button Width="64"
                            Margin="0,0,6,0"
                            Content="Play"
                            Click="PlayRecordingHistoryItemButton_Click" />
                    <Button Width="64"
                            Content="Delete"
                            Click="DeleteRecordingHistoryItemButton_Click" />
                </WrapPanel>
            </Grid>
        </StackPanel>

        <vlc:VideoView x:Name="VideoSurface"
                       Grid.Row="2"
                       MouseLeftButtonDown="VideoSurface_MouseLeftButtonDown" />

        <Border x:Name="PlayerStatusBar" Grid.Row="3" Background="{DynamicResource PlayerChromeBrush}" Padding="12,8">
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource InverseMutedTextBrush}"
                       Text="Ready." />
        </Border>
    </Grid>
</Window>
