<Window x:Class="Schmube.ListingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TV Listings"
        Height="800"
        Width="1380"
        MinHeight="700"
        MinWidth="1120"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="Manual">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="TV Listings" />
            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="Open a football match page, generate compatible playlist channels from its broadcaster listing, then use the result as a temporary navigation list." />
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,0,0,12" LastChildFill="True">
            <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                <Button x:Name="GoButton"
                        Width="76"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Go"
                        Click="GoButton_Click" />
                <Button x:Name="OpenExternalButton"
                        Width="110"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Open External"
                        Click="OpenExternalButton_Click" />
                <Button x:Name="GenerateButton"
                        Width="144"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Generate Channels"
                        Click="GenerateButton_Click" />
                <Button x:Name="UseTempListButton"
                        Width="132"
                        Height="32"
                        Margin="0,0,8,0"
                        Content="Use Temp List"
                        Click="UseTempListButton_Click" />
                <Button Width="74"
                        Height="32"
                        Content="Close"
                        Click="CloseButton_Click" />
            </WrapPanel>

            <StackPanel Margin="0,0,12,0">
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Match Listings URL" />
                <TextBox x:Name="ListingUrlTextBox"
                         Height="32"
                         Padding="10,6"
                         VerticalContentAlignment="Center" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.05*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6">
                <wv2:WebView2 x:Name="ListingsBrowser" />
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource DividerBrush}"
                          ShowsPreview="True" />

            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Compatible Channel Generator" />
                        <TextBlock x:Name="ResultsSummaryTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="Generate a compatible channel list from a rendered match page." />
                        <TextBlock x:Name="SourceSummaryTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource TertiaryTextBrush}"
                                   Text="Playlist channels available: 0." />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Search Results" />
                        <TextBox x:Name="ResultSearchTextBox"
                                 Height="32"
                                 Padding="10,6"
                                 TextChanged="ResultSearchTextBox_TextChanged" />
                    </StackPanel>

                    <TabControl Grid.Row="2">
                        <TabItem Header="Channels">
                            <ListView x:Name="GeneratedChannelsListView"
                                      SelectionMode="Extended"
                                      SelectionChanged="GeneratedChannelsListView_SelectionChanged">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Channel" Width="170" DisplayMemberBinding="{Binding ChannelName}" />
                                        <GridViewColumn Header="Group" Width="116" DisplayMemberBinding="{Binding ChannelGroup}" />
                                        <GridViewColumn Header="Source Offers" Width="240" DisplayMemberBinding="{Binding OfferPreview}" />
                                        <GridViewColumn Header="Score" Width="54" DisplayMemberBinding="{Binding BestScore}" />
                                        <GridViewColumn Header="Reason" Width="220" DisplayMemberBinding="{Binding MatchReason}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>

                        <TabItem Header="Broadcasters">
                            <ListView x:Name="OfferMatchesListView"
                                      SelectionMode="Extended">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Country" Width="118" DisplayMemberBinding="{Binding Country}" />
                                        <GridViewColumn Header="Broadcaster" Width="170" DisplayMemberBinding="{Binding Broadcaster}" />
                                        <GridViewColumn Header="Matches" Width="56" DisplayMemberBinding="{Binding MatchCount}" />
                                        <GridViewColumn Header="Top Match" Width="170" DisplayMemberBinding="{Binding TopMatch}" />
                                        <GridViewColumn Header="Reason" Width="220" DisplayMemberBinding="{Binding MatchReason}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>

                        <TabItem Header="Unmatched">
                            <ListView x:Name="UnmatchedOffersListView"
                                      SelectionMode="Extended">
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Country" Width="118" DisplayMemberBinding="{Binding Country}" />
                                        <GridViewColumn Header="Broadcaster" Width="200" DisplayMemberBinding="{Binding Broadcaster}" />
                                        <GridViewColumn Header="Reason" Width="290" DisplayMemberBinding="{Binding MatchReason}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>

                        <TabItem Header="Diagnostics">
                            <TextBox x:Name="DiagnosticsTextBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12" />
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Background="{DynamicResource StatusSurfaceBrush}"
                CornerRadius="8"
                Padding="12,10">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="{DynamicResource InverseTextBrush}"
                       Text="Open a listings page, wait for it to finish loading, then click Generate Channels." />
        </Border>
    </Grid>
</Window>
